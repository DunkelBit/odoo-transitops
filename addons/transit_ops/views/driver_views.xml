<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Driver Search View -->
    <record id="driver_search_view" model="ir.ui.view">
        <field name="name">transitops.driver.search</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="license_number"/>
                <filter name="available" string="Available" domain="[('status', '=', 'available')]"/>
                <filter name="on_trip" string="On Trip" domain="[('status', '=', 'on_trip')]"/>
                <filter name="off_duty" string="Off Duty" domain="[('status', '=', 'off_duty')]"/>
                <separator/>
                <filter name="license_expired" string="License Expired" domain="[('license_status', '=', 'expired')]"/>
                <filter name="license_expiring" string="License Expiring Soon" domain="[('license_status', '=', 'expiring_soon')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_license" string="License Status" context="{'group_by': 'license_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Driver List View -->
    <record id="driver_list_view" model="ir.ui.view">
        <field name="name">transitops.driver.list</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="license_number"/>
                <field name="license_expiry"/>
                <field name="license_status" widget="badge" decoration-success="license_status == 'valid'" decoration-warning="license_status == 'expiring_soon'" decoration-danger="license_status == 'expired'"/>
                <field name="phone"/>
                <field name="status" widget="badge" decoration-success="status == 'available'" decoration-warning="status == 'on_trip'" decoration-muted="status == 'off_duty'"/>
            </tree>
        </field>
    </record>

    <!-- Driver Form View -->
    <record id="driver_form_view" model="ir.ui.view">
        <field name="name">transitops.driver.form</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="available,on_trip,off_duty"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object" class="oe_stat_button" icon="fa-road">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value"><field name="trip_count"/></span>
                                <span class="o_stat_text">Trips</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Driver Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="license_number"/>
                            <field name="license_expiry"/>
                            <field name="license_status" widget="badge" decoration-success="license_status == 'valid'" decoration-warning="license_status == 'expiring_soon'" decoration-danger="license_status == 'expired'"/>
                        </group>
                        <group>
                            <field name="phone"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Trips" name="trips">
                            <field name="trip_ids"/>
                        </page>
                        <page string="Vehicles" name="vehicles">
                            <field name="vehicle_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Driver Kanban View -->
    <record id="driver_kanban_view" model="ir.ui.view">
        <field name="name">transitops.driver.kanban</field>
        <field name="model">transitops.driver</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="status" sample="1">
                <field name="name"/>
                <field name="license_number"/>
                <field name="license_status"/>
                <field name="status"/>
                <field name="trip_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <strong>License: </strong>
                                    <field name="license_number"/>
                                </div>
                                <div>
                                    <field name="license_status" widget="label_selection" options="{'classes': {'valid': 'success', 'expiring_soon': 'warning', 'expired': 'danger'}}"/>
                                </div>
                                <div>
                                    <strong>Trips: </strong>
                                    <field name="trip_count"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Driver Action -->
    <record id="driver_action" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">transitops.driver</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="driver_search_view"/>
    </record>
</odoo>
