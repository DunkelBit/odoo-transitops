<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Trip Search View -->
    <record id="trip_search_view" model="ir.ui.view">
        <field name="name">transitops.trip.search</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="origin"/>
                <field name="destination"/>
                <filter name="draft" string="Draft" domain="[('status', '=', 'draft')]"/>
                <filter name="dispatched" string="Dispatched" domain="[('status', '=', 'dispatched')]"/>
                <filter name="in_transit" string="In Transit" domain="[('status', '=', 'in_transit')]"/>
                <filter name="completed" string="Completed" domain="[('status', '=', 'completed')]"/>
                <separator/>
                <filter name="this_week" string="This Week" domain="[('create_date', '>=', (context_today() - relativedelta(weeks=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="this_month" string="This Month" domain="[('create_date', '>=', (context_today()).strftime('%Y-%m-01'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter name="group_driver" string="Driver" context="{'group_by': 'driver_id'}"/>
                    <filter name="group_destination" string="Destination" context="{'group_by': 'destination'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Trip List View -->
    <record id="trip_list_view" model="ir.ui.view">
        <field name="name">transitops.trip.list</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="origin"/>
                <field name="destination"/>
                <field name="departure_date"/>
                <field name="arrival_date"/>
                <field name="cargo_weight"/>
                <field name="status" widget="badge" decoration-success="status == 'completed'" decoration-info="status == 'draft'" decoration-warning="status in ('dispatched', 'in_transit')" decoration-danger="status == 'cancelled'"/>
                <field name="revenue" sum="Total"/>
            </list>
        </field>
    </record>

    <!-- Trip Form View -->
    <record id="trip_form_view" model="ir.ui.view">
        <field name="name">transitops.trip.form</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_dispatch" type="object" string="Dispatch" class="oe_highlight" invisible="status != 'draft'"/>
                    <button name="action_start" type="object" string="Start Trip" class="oe_highlight" invisible="status != 'dispatched'"/>
                    <button name="action_complete" type="object" string="Complete" class="oe_highlight" invisible="status != 'in_transit'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="status in ('completed', 'cancelled')"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft" invisible="status != 'cancelled'"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,dispatched,in_transit,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="driver_id"/>
                            <field name="origin"/>
                            <field name="destination"/>
                        </group>
                        <group>
                            <field name="departure_date"/>
                            <field name="arrival_date"/>
                            <field name="distance_km"/>
                            <field name="fuel_consumed"/>
                        </group>
                    </group>
                    <group string="Cargo & Financials">
                        <group>
                            <field name="cargo_description"/>
                            <field name="cargo_weight"/>
                        </group>
                        <group>
                            <field name="revenue"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Trip Kanban View -->
    <record id="trip_kanban_view" model="ir.ui.view">
        <field name="name">transitops.trip.kanban</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="status" sample="1">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="origin"/>
                <field name="destination"/>
                <field name="status"/>
                <field name="cargo_weight"/>
                <field name="revenue"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <strong>Vehicle: </strong>
                                    <field name="vehicle_id"/>
                                </div>
                                <div>
                                    <strong>Driver: </strong>
                                    <field name="driver_id"/>
                                </div>
                                <div>
                                    <i class="fa fa-map-marker"/> <field name="origin"/>
                                    <i class="fa fa-long-arrow-right"/>
                                    <field name="destination"/>
                                </div>
                                <div>
                                    <strong>Cargo: </strong>
                                    <field name="cargo_weight"/>
                                    <span>t</span>
                                    <span> | </span>
                                    <field name="revenue" widget="monetary"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="o_kanban_record_bottom_left">
                                    <field name="status" widget="label_selection" options="{'classes': {'draft': 'default', 'dispatched': 'info', 'in_transit': 'warning', 'completed': 'success', 'cancelled': 'danger'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Trip Action -->
    <record id="trip_action" model="ir.actions.act_window">
        <field name="name">Trips</field>
        <field name="res_model">transitops.trip</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="trip_search_view"/>
    </record>
</odoo>
