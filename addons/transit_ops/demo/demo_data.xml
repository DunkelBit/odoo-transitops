            <field name="description">Engine overheating repair</field>
            <field name="cost">3500</field>
            <field name="date_start" eval="(DateTime.today() - relativedelta(weeks=3)).strftime('%Y-%m-%d')"/>
            <field name="date_end" eval="(DateTime.today() - relativedelta(weeks=2)).strftime('%Y-%m-%d')"/>
            <field name="status">completed</field>
        </record>
