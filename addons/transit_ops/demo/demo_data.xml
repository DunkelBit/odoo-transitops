        <!-- Demo Drivers -->
        <record id="driver_1" model="transitops.driver">
            <field name="name">John Smith</field>
            <field name="license_number">DL-2024-001</field>
            <field name="license_expiry" eval="(DateTime.today() + relativedelta(months=18)).strftime('%Y-%m-%d')"/>
            <field name="phone">+1-555-0101</field>
        </record>

        <record id="driver_2" model="transitops.driver">
            <field name="name">Maria Garcia</field>
            <field name="license_number">DL-2024-002</field>
            <field name="license_expiry" eval="(DateTime.today() + relativedelta(months=6)).strftime('%Y-%m-%d')"/>
