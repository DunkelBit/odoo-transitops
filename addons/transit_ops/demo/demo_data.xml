        <!-- Demo Trips -->
        <record id="trip_1" model="transitops.trip">
            <field name="vehicle_id" ref="vehicle_1"/>
            <field name="driver_id" ref="driver_1"/>
            <field name="origin">New York, NY</field>
            <field name="destination">Boston, MA</field>
            <field name="cargo_description">Electronics equipment</field>
            <field name="cargo_weight">18.5</field>
            <field name="distance_km">350</field>
            <field name="fuel_consumed">85</field>
            <field name="revenue">2500</field>
            <field name="status">completed</field>
        </record>

