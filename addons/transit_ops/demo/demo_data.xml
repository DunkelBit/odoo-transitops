        <!-- Demo Vehicles -->
        <record id="vehicle_1" model="transitops.vehicle">
            <field name="name">TRK-001</field>
            <field name="model_name">Volvo FH16</field>
            <field name="vehicle_type">truck</field>
            <field name="max_load_capacity">25.0</field>
            <field name="fuel_capacity">400.0</field>
            <field name="current_odometer">125000</field>
            <field name="acquisition_cost">85000</field>
        </record>

