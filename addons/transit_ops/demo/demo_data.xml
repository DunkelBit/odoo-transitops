        </record>

        <!-- Demo Maintenance Records -->
        <record id="maintenance_1" model="transitops.maintenance">
            <field name="vehicle_id" ref="vehicle_1"/>
            <field name="maintenance_type">preventive</field>
            <field name="description">Regular oil change and filter replacement</field>
            <field name="cost">450</field>
            <field name="date_start" eval="(DateTime.today() - relativedelta(months=2)).strftime('%Y-%m-%d')"/>
            <field name="date_end" eval="(DateTime.today() - relativedelta(months=2) + relativedelta(days=1)).strftime('%Y-%m-%d')"/>
            <field name="status">completed</field>
        </record>

        <record id="maintenance_2" model="transitops.maintenance">
            <field name="vehicle_id" ref="vehicle_2"/>
            <field name="maintenance_type">corrective</field>
            <field name="description">Brake pad replacement</field>
            <field name="cost">1200</field>
            <field name="date_start" eval="(DateTime.today() - relativedelta(months=1)).strftime('%Y-%m-%d')"/>
            <field name="date_end" eval="(DateTime.today() - relativedelta(months=1) + relativedelta(days=3)).strftime('%Y-%m-%d')"/>
